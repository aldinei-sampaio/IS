<!-- Invisible upper tap target; stops propagation so tapping the upper area never advances the story -->
<div class="controls-taptarget" @onclick="OnUpperAreaTap" @onclick:stopPropagation="true"></div>

@if (isVisible)
{
    <div class="controls-bar" @onclick:stopPropagation="true">
        <button class="controls-btn" @onclick="GoHome" title="Biblioteca">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                <polyline points="9 22 9 12 15 12 15 22" />
            </svg>
        </button>
        <button class="controls-btn" @onclick="GoTrophies" title="Troféus">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
                <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
                <path d="M4 22h16" />
                <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22" />
                <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22" />
                <path d="M18 2H6v7a6 6 0 0 0 12 0V2z" />
            </svg>
        </button>
        <button class="controls-btn" @onclick="ToggleSound" title="@(AudioService.IsEnabled ? "Desativar música" : "Ativar música")">
            @if (AudioService.IsEnabled)
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
                    <line x1="23" y1="9" x2="17" y2="15" />
                    <line x1="17" y1="9" x2="23" y2="15" />
                </svg>
            }
        </button>
        <button class="controls-btn controls-btn-right" @onclick="GoBack" title="Voltar" disabled="@(SlideCount <= 1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6" />
            </svg>
        </button>
    </div>
}

@if (isIndicatorVisible)
{
    <button class="controls-indicator" @onclick="OnIndicatorTap" @onclick:stopPropagation="true" title="Toque para continuar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 11V6a1 1 0 0 1 2 0v5" />
            <path d="M11 11V9a1 1 0 0 1 2 0v2" />
            <path d="M13 11v-1.5a1 1 0 0 1 2 0V14c0 2.5-1.5 4-4 4s-4-1.5-4-4v-2.5a1 1 0 0 1 2 0V11" />
        </svg>
    </button>
}
